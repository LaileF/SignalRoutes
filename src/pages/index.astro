---

<html lang="en">
<head>
  <title>SignalRoutes</title>
</head>

<body>

<div class="bg"></div>

<main id="scene">

  <!-- CENTER HUB -->
  <div class="hub">
    <div class="hub-glow"></div>

    <div class="hub-card">
      <img src="/logo.png" />
      <h1>SignalRoutes</h1>
      <p class="tag">Clear signals. Better decisions.</p>
      <p class="desc">
        A system of tools designed to cut through noise across money,
        business, news, and compliance—so you always know what matters
        and what to do next.
      </p>
    </div>
  </div>

  <!-- CARDS -->

  <div class="card tl">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>Build your business with clarity. Know what to do now—and what not to do.</p>
    <a href="https://founder-routes-app-rep-production.up.railway.app/" target="_blank">Visit →</a>
  </div>

  <div class="card tr">
    <img src="/spendscore.png" class="spend" />
    <h3>SpendScore</h3>
    <p>Understand your money in real time. Build better habits without complexity.</p>
    <span>Launching April 1</span>
  </div>

  <div class="card bl">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. What’s true. Nothing extra.</p>
    <a href="https://forms.gle/ZmfuxiLXw5wnSC257">Join waitlist →</a>
  </div>

  <div class="card br">
    <div class="icon">⚖️</div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without drowning in updates.</p>
    <span>Coming soon</span>
  </div>

</main>

<style>

/* BASE */
body {
  margin:0;
  font-family: system-ui, sans-serif;
  background:#f4f2ee;
  overflow:hidden;
}

/* BACKGROUND BASE */
.bg {
  position: fixed;
  inset: 0;

  background:
    radial-gradient(circle at center, rgba(180,140,40,0.25), transparent 60%),
    url('/circuit.png');

  background-repeat: no-repeat;
  background-position: center;
  background-size: cover; /* 👈 THIS is the key change */
}

/* SIGNAL FLOW (SUBTLE MOTION) */
.bg::before {
  content:"";
  position:absolute;
  inset:0;

  background:
    linear-gradient(
      rgba(40,120,80,0.25),
      rgba(180,140,40,0.25)
    );

  mix-blend-mode: multiply;

  .bg::after {
  content:"";
  position:absolute;
  inset:0;

  background:
    radial-gradient(circle at center, rgba(180,140,40,0.35), transparent 60%);

  pointer-events:none;
}

@keyframes signalPulse {
  0% { transform: translate(-50%, -50%) scale(0.9); opacity: 0.2; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.35; }
  100% { transform: translate(-50%, -50%) scale(0.9); opacity: 0.2; }
}

/* OPTIONAL NODE DOTS */
.bg::before {
  content:"";
  position:absolute;
  inset:0;

  background:
    radial-gradient(circle, rgba(34,197,94,0.4) 2px, transparent 3px);

  background-size: 180px 180px;
  opacity:0.15;
}

/* FLOATING SIGNAL */
.bg::before {
  content:"";
  position:absolute;
  inset:0;
  background:
    radial-gradient(circle, rgba(34,197,94,0.35) 0%, transparent 60%);
  animation: drift 14s linear infinite;
  opacity:0.15;
}

@keyframes drift {
  0% { transform: translate(-20%, -10%); }
  50% { transform: translate(20%, 10%); }
  100% { transform: translate(-20%, -10%); }
}

/* SCENE */
#scene {
  position:relative;
  height:100vh;
  transition: transform 0.08s ease-out;
}

/* HUB */
.hub {
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
}

.hub-glow {
  position:absolute;
  width:420px;
  height:420px;
  background:radial-gradient(circle, rgba(180,140,40,0.35), transparent);
  animation:pulse 3s infinite;
}

.hub-card {
  position:relative;
  width:380px;
  padding:32px;
  background:white;
  border-radius:20px;
  text-align:center;
  box-shadow:0 30px 80px rgba(0,0,0,0.12);
}

.hub-card img { height:70px; }

.tag { font-weight:600; }

.desc {
  font-size:14px;
  color:#555;
  line-height:1.5;
}

/* CARDS */
.card {
  position:absolute;
  width:360px;
  padding:28px;
  background:rgba(255,255,255,0.85);
  backdrop-filter: blur(6px);
  border-radius:20px;
  box-shadow:0 20px 60px rgba(0,0,0,0.08);
  transition: all .25s ease;
}

.card img { width:52px; }
.spend { width:42px; }

/* HOVER */
.card:hover {
  transform:translateY(-8px) scale(1.04);
  box-shadow:0 30px 100px rgba(180,140,40,0.35);
}

/* POSITIONS */
.tl { top:6%; left:6%; }
.tr { top:6%; right:6%; }
.bl { bottom:6%; left:6%; }
.br { bottom:6%; right:6%; }

/* ICON */
.icon {
  width:52px;
  height:52px;
  background:#fafafa;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:10px;
}

/* ANIMATION */
@keyframes pulse {
  0% { opacity:0.4; transform:scale(1); }
  50% { opacity:1; transform:scale(1.15); }
  100% { opacity:0.4; transform:scale(1); }
}

</style>

<script>
const scene = document.getElementById("scene");

document.addEventListener("mousemove", (e) => {
  const x = (e.clientX / window.innerWidth - 0.5) * 10;
  const y = (e.clientY / window.innerHeight - 0.5) * 10;
  scene.style.transform = `translate(${x}px, ${y}px)`;
});
</script>

</body>
</html>