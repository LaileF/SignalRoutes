<style>
body {
  margin: 0;
  font-family: system-ui, sans-serif;
  overflow: hidden;
}

/* BACKGROUND (lighter + cleaner) */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;

  background:
    radial-gradient(circle at center, rgba(200,160,60,0.18), transparent 60%),
    linear-gradient(135deg, #0c1f2e 0%, #134e3a 100%);
}

/* CIRCUIT (VISIBLE AGAIN) */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;

  background: url('/circuit.png') center/1400px no-repeat;
  opacity: 0.18; /* ← key fix */
  filter: hue-rotate(140deg);

  z-index: -1;
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
  transition: transform 0.08s ease-out;
}

/* HUB */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hub-glow {
  position: absolute;
  width: 480px;
  height: 480px;
  background: radial-gradient(circle, rgba(200,160,60,0.25), transparent);
  filter: blur(40px);
  animation: pulse 4s infinite ease-in-out;
}

@keyframes pulse {
  0%,100% { opacity: 0.25; }
  50% { opacity: 0.4; }
}

.hub-card {
  position: relative;
  background: white;
  padding: 36px;
  border-radius: 18px;
  width: 300px;
  text-align: center;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
}

/* CARDS (ACTUALLY BIGGER NOW) */
.card {
  position: absolute;
  width: 340px;   /* 👈 bigger */
  padding: 26px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  transition: all 0.2s ease;
}

.card:hover {
  transform: translateY(-6px);
}

/* POSITIONS (closer in) */
.top-left     { top: 22%; left: 26%; }
.top-right    { top: 22%; right: 26%; }
.bottom-left  { bottom: 22%; left: 26%; }
.bottom-right { bottom: 22%; right: 26%; }

/* LOGOS (FIX SIZE) */
.card img {
  width: 56px;
  margin-bottom: 14px;
}

/* TEXT */
h3 { margin: 6px 0; }
p  { font-size: 14px; color: #444; }

/* LINKS */
a {
  font-size: 14px;
  color: #2563eb;
  text-decoration: none;
}
</style>

<div class="bg"></div>

<div id="scene">

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-glow"></div>
    <div class="hub-card">
      <img src="/logo.png" width="48" />
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:13px;">
        Apps designed to cut through noise across money, business, news, and compliance—so you always know what matters and clairty on what to do next.
      </p>
    </div>
  </div>

  <!-- FOUNDERROUTES -->
  <div class="card top-left">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>
      Build your business with clarity, custom downloads and an assitant that grows with you. Know what to do now—and what not to do.
    </p>
    <a href="https://founder-routes-app-rep-production.up.railway.app/" target="_blank">
      Visit →
    </a>
  </div>

  <!-- SPENDSCORE -->
  <div class="card top-right">
    <img src="/spendscore.png" />
    <h3>SpendScore</h3>
    <p>
      Understand your money in real time, track you score. Build better habits without complexity.
    </p>
    <p style="font-size:12px;">Launching April 1</p>
  </div>

  <!-- SOURCEBRIEF -->
  <div class="card bottom-left">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>
      The news, distilled. What matters to you. What’s true. Nothing extra.
    </p>
    <a href="https://forms.gle/diLbSQKf6aKchR3w7" target="_blank">
      Join waitlist →
    </a>
  </div>

  <!-- COMPLIANCE -->
  <div class="card bottom-right">
    <img src="/compliance.png" /> <!-- 👈 FIX THIS FILE NAME -->
    <h3>ComplianceIQ</h3>
    <p>
      Stay ahead of compliance without drowning in updates or spreadsheets.
    </p>
    <p style="font-size:12px;">Coming soon</p>
  </div>

</div>