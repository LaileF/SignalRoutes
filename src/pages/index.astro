---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>SignalRoutes</title>

    <style>
      /* RESET */
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #f4f2ee;
      }

      /* BACKGROUND */
      .bg {
        position: fixed;
        inset: 0;
        z-index: 0;

        background:
          radial-gradient(circle at center, rgba(180,140,40,0.25), transparent 60%),
          url('/circuit.png');

        background-repeat: no-repeat;
        background-position: center;
        background-size: 1100px;
      }

      /* COLOR OVERLAY (blue → green) */
      .bg::before {
        content: "";
        position: absolute;
        inset: 0;

        background: linear-gradient(
          rgba(30, 90, 160, 0.25),   /* blue */
          rgba(40, 140, 90, 0.25)    /* green */
        );

        mix-blend-mode: multiply;
      }

      /* SOFT CENTER GLOW */
      .bg::after {
        content: "";
        position: absolute;
        inset: 0;

        background: radial-gradient(
          circle at center,
          rgba(180,140,40,0.35),
          transparent 65%
        );
      }

      /* LAYOUT */
      #scene {
        position: relative;
        z-index: 1;
        height: 100vh;
      }

      /* CENTER HUB */
      .hub {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }

      .hub-card {
        width: 320px;
        padding: 24px;
        border-radius: 16px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        text-align: center;
      }

      /* APP CARDS */
      .card {
        position: absolute;
        width: 280px;
        padding: 20px;
        border-radius: 14px;
        background: white;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        transition: all 0.2s ease;
      }

      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(40,140,90,0.25);
      }

      /* POSITIONS */
      .top-left { top: 10%; left: 8%; }
      .top-right { top: 10%; right: 8%; }
      .bottom-left { bottom: 10%; left: 8%; }
      .bottom-right { bottom: 10%; right: 8%; }

      h2 {
        margin: 10px 0 8px;
        font-size: 20px;
      }

      p {
        font-size: 14px;
        color: #444;
      }

      a {
        color: #2563eb;
        text-decoration: none;
        font-size: 14px;
      }
    </style>
  </head>

  <body>

    <div class="bg"></div>

    <div id="scene">

      <!-- CENTER -->
      <div class="hub">
        <div class="hub-card">
          <img src="/logo.png" width="50" />
          <h2>SignalRoutes</h2>
          <p>
            Clear signals. Better decisions.<br><br>
            A system of tools designed to cut through noise across money,
            business, news, and compliance.
          </p>
        </div>
      </div>

      <!-- CARDS -->
      <div class="card top-left">
        <h3>FounderRoutes</h3>
        <p>Build your business with clarity.</p>
        <a href="https://founder-routes-app-rep-production.up.railway.app/">Visit →</a>
      </div>

      <div class="card top-right">
        <h3>SpendScore</h3>
        <p>Understand your money in real time.</p>
        <p>Launching April 1</p>
      </div>

      <div class="card bottom-left">
        <h3>SourceBrief</h3>
        <p>The news, distilled.</p>
        <a href="#">Join waitlist →</a>
      </div>

      <div class="card bottom-right">
        <h3>ComplianceIQ</h3>
        <p>Stay ahead of compliance.</p>
        <p>Coming soon</p>
      </div>

    </div>

  </body>
</html>