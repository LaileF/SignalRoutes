<html lang="en">
  <head>
    <title>SignalRoutes</title>
  </head>

  <body style="
    font-family: system-ui, sans-serif;
    margin:0;
    background:#f8f7f4;
    color:#1a1a1a;
  ">

    <!-- MAIN WRAP -->
    <main style="
      max-width:1300px;
      margin:40px auto;
      padding:20px;
    ">

      <!-- HERO (THIS FIXES EMPTY FEEL) -->
      <div style="
        text-align:center;
        margin-bottom:60px;
      ">
        <img src="/logo.png" style="height:80px;" />

        <h1 style="
          margin:10px 0;
          font-size:40px;
          letter-spacing:-1px;
        ">
          SignalRoutes
        </h1>

        <p style="
          font-size:18px;
          font-weight:500;
          margin:0;
        ">
          Clear signals. Better decisions.
        </p>

        <p style="
          max-width:720px;
          margin:12px auto 0;
          color:#555;
          line-height:1.6;
        ">
          A system of tools designed to cut through noise across money, business, news, and compliance.
        </p>
      </div>

 <div style="
  position:relative;
  display:grid;
  grid-template-columns: repeat(2, 1fr);
  gap:40px;
  margin-top:60px;
">

  <!-- subtle connection lines -->
  <div style="
    position:absolute;
    inset:0;
    background:
      linear-gradient(#eaeaea 1px, transparent 1px),
      linear-gradient(90deg, #eaeaea 1px, transparent 1px);
    background-size: 120px 120px;
    opacity:0.25;
    z-index:0;
  "></div>

  <!-- FounderRoutes (top left) -->
  <div style="
    position:relative;
    z-index:1;
    padding:24px;
    border-radius:16px;
    background:white;
    border:1px solid #e5e5e5;
    transform:translateY(-20px);
  ">
    <img src="/founderroutes.png" style="width:52px;" />
    <h3>FounderRoutes</h3>
    <p>Build your business with clarity. Know what to do now—and what not to do.</p>
    <a href="#">Visit →</a>
  </div>

  <!-- SpendScore (top right) -->
  <div style="
    position:relative;
    z-index:1;
    padding:24px;
    border-radius:16px;
    background:white;
    border:1px solid #e5e5e5;
    transform:translateY(20px);
  ">
    <img src="/spendscore.png" style="width:52px;" />
    <h3>SpendScore</h3>
    <p>Understand your money in real time. Build better habits without complexity.</p>
    <p style="font-size:13px;color:#666;">Launching April 1</p>
  </div>

  <!-- SourceBrief (bottom left) -->
  <div style="
    position:relative;
    z-index:1;
    padding:24px;
    border-radius:16px;
    background:white;
    border:1px solid #e5e5e5;
    transform:translateY(20px);
  ">
    <img src="/sourcebrief.png" style="width:52px;" />
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. What’s true.</p>
    <a href="YOUR_LINK" target="_blank">Join waitlist →</a>
  </div>

  <!-- ComplianceIQ (bottom right) -->
  <div style="
    position:relative;
    z-index:1;
    padding:24px;
    border-radius:16px;
    background:white;
    border:1px solid #e5e5e5;
    transform:translateY(-20px);
  ">
    <div style="
      width:52px;height:52px;
      display:flex;align-items:center;justify-content:center;
      background:#fafafa;border-radius:8px;
    ">⚖️</div>

    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without drowning in updates.</p>
    <p style="font-size:13px;color:#777;">Coming soon</p>
  </div>

</div>

      <!-- FOOT -->
      <p style="
        text-align:center;
        margin-top:60px;
        color:#666;
      ">
        Clarity first. Direction next.
      </p>

    </main>
  </body>
</html>