<style>
body {
  margin: 0;
  font-family: system-ui, sans-serif;
  overflow: hidden;
}

/* 🌤 LIGHTER BACKGROUND */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;

  background: linear-gradient(135deg, #12263a 0%, #1f4e6b 100%);
}

/* CIRCUIT — CLEAR BUT SOFT */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url('/circuit.png') center/1400px no-repeat;
  opacity: 0.22;
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
}

/* CENTER */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hub-card {
  background: white;
  padding: 36px;
  border-radius: 18px;
  width: 340px;
  text-align: center;
  box-shadow: 0 25px 70px rgba(0,0,0,0.25);
}

/* CARDS (CLICKABLE NOW) */
.card {
  position: absolute;
  width: 360px;
  padding: 26px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  cursor: pointer;
  transition: all 0.2s ease;
}

.card:hover {
  transform: translateY(-6px) scale(1.02);
}

/* POSITIONS */
.top-left     { top: 10%; left: 10%; }
.top-right    { top: 10%; right: 10%; }
.bottom-left  { bottom: 10%; left: 10%; }
.bottom-right { bottom: 10%; right: 10%; }

/* LOGO NORMALIZATION */
.logo-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 70px;
  margin-bottom: 10px;
}

.logo-wrap img {
  max-height: 60px;
  max-width: 100%;
  object-fit: contain;
}

/* TEXT */
h3 { margin: 6px 0; }
p { font-size: 14px; color: #444; }

/* MODAL */
.modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.modal-content {
  background: white;
  padding: 30px;
  border-radius: 16px;
  width: 400px;
  text-align: center;
}

.modal button {
  margin-top: 20px;
  padding: 8px 16px;
  border: none;
  background: #2563eb;
  color: white;
  border-radius: 6px;
}

</style>

<div class="bg"></div>

<div id="scene">

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-card">
      <div class="logo-wrap">
        <img src="/logo.png" />
      </div>
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:13px;">
        Apps designed to cut through noise across money, business, news, and compliance.
      </p>
    </div>
  </div>

  <!-- CARDS -->
  <div class="card top-left" onclick="openModal('founder')">
    <div class="logo-wrap"><img src="/founderroutes.png" /></div>
    <h3>FounderRoutes</h3>
    <p>Build your business with direction—not guesswork.</p>
  </div>

  <div class="card top-right" onclick="openModal('spend')">
    <div class="logo-wrap"><img src="/spendscore.png" /></div>
    <h3>SpendScore</h3>
    <p>Understand your money in real time.</p>
  </div>

  <div class="card bottom-left" onclick="openModal('source')">
    <div class="logo-wrap"><img src="/sourcebrief.png" /></div>
    <h3>SourceBrief</h3>
    <p>The news, distilled.</p>
  </div>

  <div class="card bottom-right" onclick="openModal('compliance')">
    <div class="logo-wrap"><img src="/compliance.png" /></div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance.</p>
  </div>

</div>

<!-- MODAL -->
<div class="modal" id="modal">
  <div class="modal-content" id="modal-content">
    <h3>Coming Soon</h3>
    <p>Details here</p>
    <button onclick="closeModal()">Close</button>
  </div>
</div>

<script>
function openModal(type) {
  const modal = document.getElementById('modal');
  const content = document.getElementById('modal-content');

  const data = {
    founder: {
      title: "FounderRoutes",
      text: "Build your business with clarity.",
      link: "https://founder-routes-app-rep-production.up.railway.app/"
    },
    spend: {
      title: "SpendScore",
      text: "Track and improve your financial habits."
    },
    source: {
      title: "SourceBrief",
      text: "Smart news summaries tailored to you.",
      link: "https://forms.gle/diLbSQKf6aKchR3w7"
    },
    compliance: {
      title: "ComplianceIQ",
      text: "Compliance made simple. Coming soon."
    }
  };

  const item = data[type];

  content.innerHTML = `
    <h3>${item.title}</h3>
    <p>${item.text}</p>
    ${item.link ? `<a href="${item.link}" target="_blank">Open →</a>` : ""}
    <br/><br/>
    <button onclick="closeModal()">Close</button>
  `;

  modal.style.display = 'flex';
}

function closeModal() {
  document.getElementById('modal').style.display = 'none';
}
</script>