---
---

<html lang="en">
<head>
  <title>SignalRoutes</title>
</head>

<body style="
  font-family: system-ui, sans-serif;
  margin:0;
  background:#f4f2ee;
  overflow:hidden;
">

<!-- BACKGROUND SYSTEM -->
<div class="bg"></div>

<main id="scene">

  <!-- CENTER HUB -->
  <div class="hub">
    <div class="hub-glow"></div>

    <div class="hub-card">
      <img src="/logo.png" />
      <h1>SignalRoutes</h1>
      <p class="tag">Clear signals. Better decisions.</p>
      <p class="desc">
        A system of tools designed to cut through noise across money,
        business, news, and compliance—so you always know what matters
        and what to do next.
      </p>
    </div>
  </div>

  <!-- CIRCUIT SYSTEM -->
  <svg class="lines" viewBox="0 0 1400 800">

  <!-- ROUTES (go around hub, not through it) -->
  <path id="p1" d="M650 350 L500 250 L200 120" />
  <path id="p2" d="M750 350 L900 250 L1200 120" />
  <path id="p3" d="M650 450 L500 550 L200 700" />
  <path id="p4" d="M750 450 L900 550 L1200 700" />

  <!-- RIGHT-ANGLE BRANCHES (this adds realism) -->
  <path d="M500 250 L500 200 L450 200" />
  <path d="M900 250 L900 200 L950 200" />
  <path d="M500 550 L500 600 L450 600" />
  <path d="M900 550 L900 600 L950 600" />

  <!-- ENDPOINT NODES ONLY -->
  <circle cx="200" cy="120" r="3" class="node"/>
  <circle cx="1200" cy="120" r="3" class="node"/>
  <circle cx="200" cy="700" r="3" class="node"/>
  <circle cx="1200" cy="700" r="3" class="node"/>

  <!-- SIGNAL (clean, not cluttered) -->
  <circle r="3" class="pulse">
    <animateMotion dur="3s" repeatCount="indefinite">
      <mpath href="#p1"/>
    </animateMotion>
  </circle>

</svg>

  <!-- CARDS -->

  <!-- FounderRoutes -->
  <div class="card tl">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>Build your business with clarity. Know what to do now—and what not to do.</p>
    <a href="https://founder-routes-app-rep-production.up.railway.app/" target="_blank">
      Visit →
    </a>
  </div>

  <!-- SpendScore (FIXED SIZE) -->
  <div class="card tr">
    <img src="/spendscore.png" class="spend" />
    <h3>SpendScore</h3>
    <p>Understand your money in real time. Build better habits without complexity.</p>
    <span>Launching April 1</span>
  </div>

  <!-- SourceBrief -->
  <div class="card bl">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. What’s true. Nothing extra.</p>
    <a href="https://forms.gle/ZmfuxiLXw5wnSC257">Join waitlist →</a>
  </div>

  <!-- ComplianceIQ -->
  <div class="card br">
    <div class="icon">⚖️</div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without drowning in updates.</p>
    <span>Coming soon</span>
  </div>

</main>

<style>

/* BACKGROUND (GREEN + GOLD SYSTEM) */
.bg {
  position:fixed;
  inset:0;
  background:
    radial-gradient(circle at center, rgba(180,140,40,0.18), transparent 65%),
    radial-gradient(circle at 20% 20%, rgba(34,197,94,0.08), transparent 40%),
    radial-gradient(circle at 80% 80%, rgba(34,197,94,0.08), transparent 40%);
}

/* MAIN */
#scene {
  position:relative;
  height:100vh;
  transition:transform 0.1s ease-out;
}

/* HUB */
.hub {
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
}

.hub-glow {
  position:absolute;
  width:420px;
  height:420px;
  background:radial-gradient(circle, rgba(180,140,40,0.35), transparent);
  animation:pulse 3s infinite;
}

.hub-card {
  position:relative;
  width:380px;
  padding:32px;
  background:white;
  border-radius:20px;
  text-align:center;
  box-shadow:0 30px 80px rgba(0,0,0,0.12);
}

.hub-card img { height:70px; }
.tag { font-weight:600; }
.desc { font-size:14px; color:#555; }

/* LINES */
.lines {
  position:absolute;
  inset:0;
}

.lines path {
  fill:none;
  stroke:rgba(34,197,94,0.22); /* 👈 softer */
  stroke-width:1.5;
  stroke-linecap:round;
}

.node {
  fill:#22c55e;
  opacity:0.7;
  filter: drop-shadow(0 0 4px #22c55e);
}

.pulse {
  fill:#22c55e;
  filter: drop-shadow(0 0 6px #22c55e);
}

/* CARDS */
.card {
  position:absolute;
  width:360px;
  padding:28px;
  background:white;
  border-radius:20px;
  box-shadow:0 15px 50px rgba(0,0,0,0.08);
  transition:all .3s ease;
}

/* ICON SIZES */
.card img { width:52px; }
.spend { width:42px; } /* 👈 FIXED SpendScore */

/* NODE GLOW */
.card::before {
  content:"";
  position:absolute;
  width:10px;
  height:10px;
  background:#22c55e;
  border-radius:50%;
  top:-6px;
  right:-6px;
  box-shadow:0 0 10px #22c55e;
}

/* HOVER = ACTIVATION */
.card:hover {
  transform:translateY(-6px) scale(1.04);
  box-shadow:0 30px 100px rgba(180,140,40,0.4);
}

.card:hover::before {
  box-shadow:0 0 20px #22c55e;
}

/* POSITIONS */
.tl { top:6%; left:6%; }
.tr { top:6%; right:6%; }
.bl { bottom:6%; left:6%; }
.br { bottom:6%; right:6%; }

/* ICON */
.icon {
  width:52px;
  height:52px;
  background:#fafafa;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:10px;
}

/* ANIMATION */
@keyframes pulse {
  0% { opacity:0.4; transform:scale(1); }
  50% { opacity:1; transform:scale(1.2); }
  100% { opacity:0.4; transform:scale(1); }
}

</style>

<script>
const scene = document.getElementById("scene");

document.addEventListener("mousemove", (e) => {
  const x = (e.clientX / window.innerWidth - 0.5) * 12;
  const y = (e.clientY / window.innerHeight - 0.5) * 12;
  scene.style.transform = `translate(${x}px, ${y}px)`;
});
</script>

</body>
</html>