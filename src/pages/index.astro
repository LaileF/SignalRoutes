---
---

<html lang="en">
<head>
  <title>SignalRoutes</title>
</head>

<body style="
  font-family: system-ui, sans-serif;
  margin:0;
  background:#f4f2ee;
  overflow:hidden;
">

<!-- BACKGROUND SYSTEM -->
<div class="bg"></div>

<main id="scene">

  <!-- CENTER HUB -->
  <div class="hub">
    <div class="hub-glow"></div>

    <div class="hub-card">
      <img src="/logo.png" />
      <h1>SignalRoutes</h1>
      <p class="tag">Clear signals. Better decisions.</p>
      <p class="desc">
        A system of tools designed to cut through noise across money,
        business, news, and compliance—so you always know what matters
        and what to do next.
      </p>
    </div>
  </div>

  <!-- CIRCUIT SYSTEM -->
  <svg class="lines">

    <!-- BRANCHING PATHS -->
    <path id="p1" d="M700 400 Q500 250 200 120" />
    <path id="p2" d="M700 400 Q900 250 1200 120" />
    <path id="p3" d="M700 400 Q500 550 200 700" />
    <path id="p4" d="M700 400 Q900 550 1200 700" />

    <!-- SIGNAL PULSES -->
    <circle r="4" class="pulse">
      <animateMotion dur="2s" repeatCount="indefinite"><mpath href="#p1"/></animateMotion>
    </circle>
    <circle r="4" class="pulse">
      <animateMotion dur="2.4s" repeatCount="indefinite"><mpath href="#p2"/></animateMotion>
    </circle>
    <circle r="4" class="pulse">
      <animateMotion dur="2.8s" repeatCount="indefinite"><mpath href="#p3"/></animateMotion>
    </circle>
    <circle r="4" class="pulse">
      <animateMotion dur="3.2s" repeatCount="indefinite"><mpath href="#p4"/></animateMotion>
    </circle>

  </svg>

  <!-- CARDS -->

  <!-- FounderRoutes -->
  <div class="card tl">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>Build your business with clarity. Know what to do now—and what not to do.</p>
    <a href="https://founder-routes-app-rep-production.up.railway.app/" target="_blank">
      Visit →
    </a>
  </div>

  <!-- SpendScore (FIXED SIZE) -->
  <div class="card tr">
    <img src="/spendscore.png" class="spend" />
    <h3>SpendScore</h3>
    <p>Understand your money in real time. Build better habits without complexity.</p>
    <span>Launching April 1</span>
  </div>

  <!-- SourceBrief -->
  <div class="card bl">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. What’s true. Nothing extra.</p>
    <a href="https://forms.gle/ZmfuxiLXw5wnSC257">Join waitlist →</a>
  </div>

  <!-- ComplianceIQ -->
  <div class="card br">
    <div class="icon">⚖️</div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without drowning in updates.</p>
    <span>Coming soon</span>
  </div>

</main>

<style>

/* BACKGROUND (GREEN + GOLD SYSTEM) */
.bg {
  position:fixed;
  inset:0;
  background:
    radial-gradient(circle at center, rgba(180,140,40,0.18), transparent 60%),
    repeating-linear-gradient(0deg, rgba(34,197,94,0.12) 0 2px, transparent 2px 120px),
    repeating-linear-gradient(90deg, rgba(34,197,94,0.12) 0 2px, transparent 2px 120px);
}

/* MAIN */
#scene {
  position:relative;
  height:100vh;
  transition:transform 0.1s ease-out;
}

/* HUB */
.hub {
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
}

.hub-glow {
  position:absolute;
  width:420px;
  height:420px;
  background:radial-gradient(circle, rgba(180,140,40,0.35), transparent);
  animation:pulse 3s infinite;
}

.hub-card {
  position:relative;
  width:380px;
  padding:32px;
  background:white;
  border-radius:20px;
  text-align:center;
  box-shadow:0 30px 80px rgba(0,0,0,0.12);
}

.hub-card img { height:70px; }
.tag { font-weight:600; }
.desc { font-size:14px; color:#555; }

/* LINES */
.lines {
  position:absolute;
  inset:0;
}

.lines path {
  fill:none;
  stroke:rgba(34,197,94,0.5);
  stroke-width:2;
}

.pulse {
  fill:#22c55e;
}

/* CARDS */
.card {
  position:absolute;
  width:360px;
  padding:28px;
  background:white;
  border-radius:20px;
  box-shadow:0 15px 50px rgba(0,0,0,0.08);
  transition:all .3s ease;
}

/* ICON SIZES */
.card img { width:52px; }
.spend { width:42px; } /* 👈 FIXED SpendScore */

/* NODE GLOW */
.card::before {
  content:"";
  position:absolute;
  width:10px;
  height:10px;
  background:#22c55e;
  border-radius:50%;
  top:-6px;
  right:-6px;
  box-shadow:0 0 10px #22c55e;
}

/* HOVER = ACTIVATION */
.card:hover {
  transform:translateY(-6px) scale(1.04);
  box-shadow:0 30px 100px rgba(180,140,40,0.4);
}

.card:hover::before {
  box-shadow:0 0 20px #22c55e;
}

/* POSITIONS */
.tl { top:6%; left:6%; }
.tr { top:6%; right:6%; }
.bl { bottom:6%; left:6%; }
.br { bottom:6%; right:6%; }

/* ICON */
.icon {
  width:52px;
  height:52px;
  background:#fafafa;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:10px;
}

/* ANIMATION */
@keyframes pulse {
  0% { opacity:0.4; transform:scale(1); }
  50% { opacity:1; transform:scale(1.2); }
  100% { opacity:0.4; transform:scale(1); }
}

</style>

<script>
const scene = document.getElementById("scene");

document.addEventListener("mousemove", (e) => {
  const x = (e.clientX / window.innerWidth - 0.5) * 12;
  const y = (e.clientY / window.innerHeight - 0.5) * 12;
  scene.style.transform = `translate(${x}px, ${y}px)`;
});
</script>

</body>
</html>